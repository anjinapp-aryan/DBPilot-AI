# ==============================================================================
# DBPilot AI — Environment Variables
# Copy this file to backend/.env (the backend reads .env relative to its own
# working directory) and fill in real values. Never commit a populated .env.
# ==============================================================================

# --- Database (Neon PostgreSQL) ---
DATABASE_URL=postgresql+psycopg://user:password@host:5432/dbname
DATABASE_URL_SYNC=postgresql://user:password@host:5432/dbname

# --- AI Gateway: routing (see backend/app/ai/) ---
# AI_PROVIDER_ORDER is a comma-separated failover chain of provider keys;
# a provider is skipped automatically unless both its api key and model are
# set below. If DeepSeek hits a rate/token limit, the gateway fails over to
# the next configured provider in this order.
PRIMARY_PROVIDER=deepseek
AI_PROVIDER_ORDER=deepseek,gemini,groq,qwen,openrouter
AI_GATEWAY_DEFAULT_TEMPERATURE=0.4

# --- NVIDIA-hosted models: DeepSeek + Qwen (OpenAI-compatible) ---
# DEEP_SHEEK_NVIDIA_API_KEY intentionally matches the upstream project's
# spelling so an existing .env can be reused unmodified.
DEEP_SHEEK_NVIDIA_API_KEY=
QWEN3_NVIDIA_API_KEY=
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_DEEPSEEK_MODEL=deepseek-ai/deepseek-v4-flash
NVIDIA_QWEN_MODEL=qwen/qwen3-next-80b-a3b-instruct
NVIDIA_TIMEOUT_MS=20000

# --- Groq (OpenAI-compatible) ---
GROQ_API_KEY=
GROQ_BASE_URL=https://api.groq.com/openai/v1
GROQ_MODEL=llama-3.3-70b-versatile

# --- Gemini (native REST API) ---
GEMINI_API_KEY=
GEMINI_BASE_URL=https://generativelanguage.googleapis.com/v1beta
GEMINI_MODEL=gemini-2.5-flash

# --- OpenRouter (final fallback — OpenAI-compatible) ---
OPENROUTER_API_KEY=
OPENROUTER_BASE_URL=https://openrouter.ai/api/v1
OPENROUTER_MODEL=

# --- Backend (FastAPI) ---
BACKEND_HOST=0.0.0.0
BACKEND_PORT=8000
BACKEND_ENV=development
ALLOWED_ORIGINS=http://localhost:3000
ALLOWED_HOSTS=*
SECRET_KEY=change-me-in-production
RATE_LIMIT_DEFAULT=60/minute

# --- Frontend (Next.js) ---
NEXT_PUBLIC_API_BASE_URL=http://localhost:8000
NEXT_PUBLIC_APP_NAME=DBPilot AI

# --- Observability (optional) ---
LOG_LEVEL=info
SENTRY_DSN=
